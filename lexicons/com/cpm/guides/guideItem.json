          "sourceLabel": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "snapshotAt": { "type": "string", "format": "datetime" },
          "createdAt": { "type": "string", "format": "datetime" },
          "updatedAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  },
