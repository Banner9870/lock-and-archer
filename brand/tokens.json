{
  "name": "Lock and Archer",
  "version": 1,
  "colors": {
    "brand_red": "#ed0000",
    "brand_red_dark": "#d60000",
    "text_1": "#252525",
    "text_2": "#636466",
    "background": "#ffffff",
    "border": "#e5e7eb",
    "gray_50": "#f9fafb",
    "gray_100": "#f3f4f6",
    "gray_200": "#e5e7eb",
    "gray_300": "#d1d5db",
    "gray_400": "#9ca3af",
    "gray_500": "#6b7280",
    "gray_600": "#4b5563",
    "gray_700": "#374151",
    "gray_800": "#1f2937",
    "gray_900": "#111827"
  },
  "semantic": {
    "text_primary": "{colors.text_1}",
    "text_secondary": "{colors.text_2}",
    "surface": "{colors.background}",
    "outline": "{colors.border}",
    "action_primary": "{colors.brand_red}",
    "link": "{colors.brand_red}",
    "state": {
      "info": "#3b82f6",
      "success": "#10b981",
      "warning": "#f59e0b",
      "danger": "#ef4444"
    }
  },
  "typography": {
    "fonts": {
      "serif_headings": "Charter, Georgia, \"Times New Roman\", serif",
      "sans_body": "Source Sans 3, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif"
    },
    "sizes": {
      "base": "1rem",
      "sm": "0.875rem",
      "lg": "1.125rem"
    }
  },
  "radii": {
    "1": "6px",
    "2": "10px",
    "3": "14px"
  },
  "shadows": {
    "1": "0 1px 2px rgba(0,0,0,.08)",
    "2": "0 2px 8px rgba(0,0,0,.12)"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "xxl": "1536px"
  }
}
